# Google Cloud Firestore Configuration
GOOGLE_CLOUD_PROJECT_ID=your-project-id
FIRESTORE_DATABASE_ID=(default)

# For production, use service account credentials
# Download the service account key file and set the path here
GOOGLE_APPLICATION_CREDENTIALS=path/to/your/service-account-key.json

# For development, you can use Application Default Credentials (ADC)
# Run: gcloud auth application-default login
# This will automatically authenticate using your Google Cloud credentials

# Vertex AI / Gemini ingestion settings
GOOGLE_CLOUD_LOCATION=global
# LLM used for scoring, URL extraction, and summarisation during ingestion
INGEST_MODEL=gemini-3.1-flash-lite
# Embedding model (Vertex AI, location: global)
EMBEDDING_MODEL=gemini-embedding-2

# Optional: Firecrawl fallback for JS-rendered pages
# FIRECRAWL_API_KEY=your-firecrawl-key
